msgstr "ئىشلەتكۈچى چاقىرىشنى يېشەلمىدى."

#: samba/filepropertiesplugin/kauth/authhelper.cpp:120
#, kde-format
msgctxt "@info"
msgid ""
"For security reasons, creating Samba users with empty passwords is not "
