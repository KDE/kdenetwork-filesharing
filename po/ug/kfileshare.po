#: samba/filepropertiesplugin/groupmanager.cpp:37
#, kde-kuit-format
msgctxt "@info:status"
msgid "Your Samba installation appears to be broken."
msgstr "سىستېمىغا ئورنىتىلغان Samba بۇزۇلغان بولۇشى مۇمكىن."

#: samba/filepropertiesplugin/groupmanager.cpp:42
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This error is caused by your distribution not setting up Samba sharing "
"properly. Please file a bug with your distribution or check your "
"distribution's documentation on setting up Samba sharing."
msgstr ""
"بۇ خاتالىق سىستېمىغا ئورنىتىلغان تارقىتىلغان نەشرىدە Samba ھەمبەھىرنىڭ توغرا "
"سەپلەنمىگەنلىكىدىن كېلىپ چىققان. تارقاتقۇچىغا كەمتۈكلۈك مەلۇماتى يوللاڭ ياكى "
"مەزكۇر تارقىتىش نەشرىدە Samba ھەمبەھىرنى قانداق سەپلەش ھەققىدىكى قوللانمىنى "
"كۆرۈڭ."

#: samba/filepropertiesplugin/groupmanager.cpp:47
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This error is caused by your distribution not setting up Samba sharing "
"properly. Please file a bug with your distribution or check your "
"distribution's documentation on setting up Samba sharing. Error:<nl/"
"><message>%1</message>"
msgstr ""
"بۇ خاتالىق سىستېمىغا ئورنىتىلغان تارقىتىلغان نەشرىدە Samba ھەمبەھىرنىڭ توغرا "
"سەپلەنمىگەنلىكىدىن كېلىپ چىققان. تارقاتقۇچىغا كەمتۈكلۈك مەلۇماتى يوللاڭ ياكى "
"مەزكۇر تارقىتىش نەشرىدە Samba ھەمبەھىرنى قانداق سەپلەش ھەققىدىكى قوللانمىنى "
"كۆرۈڭ. خاتالىق: <nl/><message>%1</message>"

#: samba/filepropertiesplugin/groupmanager.cpp:56
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This folder can't be shared because <filename>%1</filename> does not exist."
msgstr ""
"بۇ قىسقۇچنى ھەمبەھىرلىيەلمەيدۇ چۈنكى <filename>%1</filename> مەۋجۇت ئەمەس."

#: samba/filepropertiesplugin/groupmanager.cpp:59
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This error is caused by your distribution not setting up Samba sharing "
"properly. You can fix it yourself by creating that folder manually, then "
"close and re-open this window."
msgstr ""
"بۇ خاتالىق سىستېمىغا ئورنىتىلغان تارقىتىلغان نەشرىدە Samba ھەمبەھىرنىڭ توغرا "
"سەپلەنمىگەنلىكىدىن كېلىپ چىققان. ئاشۇ مۇندەرىجىنى ئۆزىڭىز قۇرۇپ مەسىلىنى "
"ئوڭشىيالايسىز ئاندىن مەزكۇر كۆزنەكنى يېپىپ، قايتا ئېچىڭ."

#: samba/filepropertiesplugin/groupmanager.cpp:72
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This folder can't be shared because your user account isn't a member of the "
"<resource>%1</resource> group."
msgstr ""
"بۇ قىسقۇچنى ھەمبەھىرلىيەلمەيدۇ چۈنكى ئىشلەتكۈچى ھېسابىڭىز <resource>%1</"
"resource> گۇرۇپپىنىڭ ئەزاسى ئەمەس."

#: samba/filepropertiesplugin/groupmanager.cpp:75
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"You can fix this by making your user a member of that group, then restart "
"the system."
msgstr ""
"بۇ مەسىلىنى ئۆزىڭىز ئوڭشىيالايسىز، ئالدى بىلەن ئىشلەتكۈچى ھېسابىنى ئاشۇ "
"گۇرۇپپىنىڭ ئەزالىقىغا قوشۇپ ئاندىن سىستېمىنى قايتا قوزغىتىڭ."

#: samba/filepropertiesplugin/groupmanager.cpp:79
#, kde-format
msgctxt "action@button makes user a member of the samba share group"
msgid "Make Me a Group Member"
msgstr "مېنى گۇرۇپپا ئەزالىقىغا كىرگۈز"

#: samba/filepropertiesplugin/groupmanager.cpp:86
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"This folder can't be shared because your user account doesn't have "
"permission to write into <filename>%1</filename>."
msgstr ""
"بۇ قىسقۇچنى ھەمبەھىرلىيەلمەيدۇ چۈنكى ئىشلەتكۈچى ھېسابىڭىز <filename>%1</"
"filename> غا يېزىش ئىجازىتى يوق."

#: samba/filepropertiesplugin/groupmanager.cpp:90
#, kde-kuit-format
msgctxt "@info:status"
msgid ""
"You can fix this by ensuring that the <resource>%1</resource> group has "
"write permission for <filename>%2</filename>, then close and re-open this "
"window."
msgstr ""
"بۇ مەسىلىنى ئۆزىڭىز ئوڭشىيالايسىز، ئالدى بىلەن <resource>%1</resource> "
"ئىشلەتكۈچى گۇرۇپپىسىنىڭ <filename>%2</filename> غا يېزىش ئىجازىتىنىڭ "
"بارلىقىنى جەزملەڭ، ئاندىن بۇ كۆزنەكنى يېپىپ، قايتا ئېچىڭ."

#: samba/filepropertiesplugin/groupmanager.cpp:121
#, kde-kuit-format
msgctxt "@label kauth action description %1 is a username %2 a group name"
msgid ""
"Adding user <resource>%1</resource> to group <resource>%2</resource> so they "
"can configure Samba user shares"
msgstr ""
"<resource>%1</resource> ئىشلەتكۈچىنى <resource>%2</resource> ئىشلەتكۈچى "
"گۇرۇپپىسىغا قوشسىڭىز، Samba ئىشلەتكۈچى ھەمبەھىرلەشنى سەپلىيەلەيدۇ"

#: samba/filepropertiesplugin/groupmanager.cpp:132
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Failed to make user <resource>%1</resource> a member of group <resource>%2</"
"resource>"
msgstr ""
"<resource>%1</resource> ئىشلەتكۈچىنى <resource>%2</resource> گۇرۇپپىنىڭ "
"ئەزالىقىغا تەڭشىيەلمىدى."

#: samba/filepropertiesplugin/kauth/authhelper.cpp:78
#, kde-kuit-format
msgctxt "@info"
msgid ""
"User name <resource>%1</resource> is not valid as the name of a Samba user; "
