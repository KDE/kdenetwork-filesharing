"@info '%1 %2' together make up a terminal command; %3 is the command's output"
msgid "Command <command>%1 %2</command> failed:<nl/><nl/>%3"
msgstr "بۇيرۇق <command>%1 %2</command> مەغلۇپ بولدى:<nl/><nl/>%3"

#: samba/filepropertiesplugin/kauth/authhelper.cpp:114
#: samba/filepropertiesplugin/kauth/authhelper.cpp:160
#, kde-kuit-format
msgctxt "@info error while looking up uid from dbus"
